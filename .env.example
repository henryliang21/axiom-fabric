# Axiom Fabric configuration — copy to `.env` and edit.
#
#   cp .env.example .env        # macOS / Linux
#   Copy-Item .env.example .env # Windows PowerShell
#
# `.env` is read automatically from the directory you run `af` from
# (via pydantic-settings). Real environment variables take precedence
# over values in this file. All settings use the `AF_` prefix.

# --- Database connection -----------------------------------------------------
# Default if unset: sqlite:///./af.db (a file in the working directory).

# SQLite, file-backed (zero setup, good for local/single-user):
AF_DATABASE_URL=sqlite:///./af.db

# SQLite, in-memory (ephemeral — lost on exit; handy for throwaway runs):
# AF_DATABASE_URL=sqlite:///:memory:

# PostgreSQL (production / multi-process). Shape:
#   postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
# Omit ":<password>" if your server trusts local connections.
# Create the database first:  createdb axiom_fabric
# AF_DATABASE_URL=postgresql+psycopg://postgres:secret@localhost:5432/axiom_fabric

# --- Logging -----------------------------------------------------------------
# Echo every SQL statement to stderr (true/false). Default: false.
# AF_ECHO_SQL=false
